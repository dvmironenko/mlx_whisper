# ========================================
# Параметры приложения
# ========================================

# --- Server Settings (Настройки сервера) ---
MLX_WHISPER_HOST=0.0.0.0          # Хост сервера (по умолчанию: 0.0.0.0)
MLX_WHISPER_PORT=8801             # Порт сервера (по умолчанию: 8801)
MLX_WHISPER_DEBUG=false           # Режим отладки (по умолчанию: false)

# --- Audio Processing (Обработка аудио) ---
MAX_FILE_SIZE_MB=500              # Максимальный размер файла в МБ (по умолчанию: 500)
CHUNK_SIZE_KB=8                   # Размер chunk для чтения файлов в КБ (по умолчанию: 8)

# --- Timeouts (Таймауты) ---
CONVERSION_TIMEOUT=600            # Таймаут конвертации аудио в секундах (по умолчанию: 600)
TRANSCRIPTION_TIMEOUT=3600        # Таймаут транскрипции в секундах (по умолчанию: 3600)

# --- Directories (Каталоги) ---
MODELS_DIR=models                 # Путь к каталогу моделей Whisper (по умолчанию: models)
RESULTS_DIR=results               # Путь к каталогу результатов (по умолчанию: results)
RESULTS_RETENTION_DAYS=30         # Срок хранения результатов в днях (по умолчанию: 30)
LOGS_DIR=logs                     # Путь к каталогу логов (по умолчанию: logs)
LOG_LEVEL=INFO                    # Уровень логирования (по умолчанию: INFO)

# --- Authentication (Аутентификация) ---
MLX_WHISPER_API_KEY=              # API ключ для аутентификации (оставить пустым для отключения)

# ========================================
# Параметры транскрипции
# ========================================

# --- Default Language (Язык по умолчанию) ---
LANGUAGE=ru                       # Язык по умолчанию для транскрипции (empty = auto-detect)
                                  # Поддерживаемые: ru, en, de, fr, es, ...

# --- Silence Removal (Удаление тишины) ---
REMOVE_SILENCE=true               # Удалять тишину в начале и конце аудио (true/false, по умолчанию: true)
SILENCE_THRESHOLD=-60.0           # Порог для обнаружения тишины в dB (по умолчанию: -60.0)
SILENCE_DURATION=0.5              # Минимальная длительность тишины для удаления в секундах (по умолчанию: 0.5)

# --- Transcription Thresholds (Пороги транскрипции) ---
NO_SPEECH_THRESHOLD=0.4           # Порог отсутствия речи (по умолчанию: 0.4)
                                  # Значения ниже этого порога считаются тишиной

HALLUCINATION_SILENCE_THRESHOLD=0.8  # Порог галлюцинаций/тишины (по умолчанию: 0.8)
                                     # Порог для определения галлюцинаций модели

# --- Initial Prompt (Начальный промпт) ---
INITIAL_PROMPT=Транскрибируй аудио файл.   # Начальный текст для контекстной транскрипции (опционально)

# --- Default Model (Модель по умолчанию) ---
MODEL=turbo                     # Модель по умолчанию: tiny, base, small, medium, turbo, large

# --- Default Task (Задача по умолчанию) ---
TASK=transcribe                   # Тип задачи по умолчанию: transcribe или translate

# --- Word Timestamps (Временные метки) ---
WORD_TIMESTAMPS=false             # Включить word-level timestamps по умолчанию

# --- Condition on Previous Text (Контекст) ---
CONDITION_ON_PREVIOUS=true        # Использовать предыдущий текст для контекста по умолчанию

# ========================================
# Прочие параметры
# ========================================
