# Server settings
MLX_WHISPER_HOST=0.0.0.0
MLX_WHISPER_PORT=8801
MLX_WHISPER_DEBUG=true

# Audio processing
MAX_FILE_SIZE_MB=2500
CHUNK_SIZE_KB=8
AUDIO_SAMPLE_RATE=32000

# Timeouts (seconds)
CONVERSION_TIMEOUT=600
TRANSCRIPTION_TIMEOUT=3600

# Models path
MODELS_DIR=models

# Results storage
RESULTS_DIR=results
RESULTS_RETENTION_DAYS=30

# Auth (optional)
MLX_WHISPER_API_KEY=

# Logging
LOGS_DIR=logs
LOG_LEVEL=DEBUG

# Initial prompt for context-aware transcription (optional)
INITIAL_PROMPT=Транскрибируйте аудио файл.

# Default language for transcription (empty string or leave blank for auto-detect)
# Supported: ru, en, de, fr, es, ...
DEFAULT_LANGUAGE=ru

# Silence removal settings
# Remove silence at start and end of audio (true/false)
REMOVE_SILENCE=true
# Silence threshold in dB (default: -45.0)
SILENCE_THRESHOLD=-45.0
# Minimum silence duration to remove in seconds (default: 1.0)
SILENCE_DURATION=1.0

# Transcription thresholds
# Threshold for detecting silence in audio (default: 0.4)
NO_SPEECH_THRESHOLD=0.35
# Threshold for detecting hallucinations/missing speech (default: 0.8)
HALLUCINATION_SILENCE_THRESHOLD=0.4

# Default transcription settings
DEFAULT_TASK=transcribe
DEFAULT_MODEL=turbo
DEFAULT_WORD_TIMESTAMPS=true
DEFAULT_CONDITION_ON_PREVIOUS=true

# ========================================
# OpenAI API для генерации отчётов
# ========================================

# API ключ OpenAI (обязательно для генерации отчётов)
OPENAI_API_KEY=1234

# URL OpenAI API (по умолчанию: https://api.openai.com/v1)
OPENAI_BASE_URL=http://studio2.mironenko.org:8880/v1

# Модель OpenAI для генерации (по умолчанию: gpt-4o-mini)
OPENAI_MODEL=Qwen3.5-9B-MLX-8bit

# Системный промпт для генерации отчётов
OPENAI_REPORT_PROMPT=Ты эксперт в области транскрипций сессий психолога с клиентом. Раздели реплики на диалоги от имени участников [Терапевт] и [Клиент]. Идущие подряд реплики одного участника объедини. Исправь грамматические ошибки и опечатки. Убрери лишние слова-паразиты и повторы. Сформируй законченные по смыслу предложения или абзацы. Не пропускать ничего. Не искажай смысл реплик. Не добавляй ничего. Форматируй текст для удобства чтения.

# ========================================
# Технические настройки
# ========================================

# Максимальный размер части текста для генерации отчёта (в символах)
MAX_REPORT_CHUNK_SIZE=128072

# ========================================
# OMLX / VibeVoice Configuration
# ========================================
OMLX_BASE_URL=http://studio2.mironenko.org:8880/v1
OMLX_MODEL=VibeVoice-ASR-8bit
#OMLX_MODEL=VibeVoice-ASR-bf16
OMLX_API_KEY=1234
OMLX_ENABLED=true

# Список моделей OMLX (формат: alias:Display Name|alias2:Display Name2)
# По умолчанию: VibeVoice-ASR-8bit:VibeVoice ASR 8-bit|VibeVoice-ASR:VibeVoice ASR
OMLX_MODELS=VibeVoice-ASR-8bit:VibeVoice ASR 8-bit|VibeVoice-ASR-bf16:VibeVoice-ASR-bf16|whisper-large-v3-turbo-asr-fp16:whisper-large-v3-turbo-asr-fp16|whisper-large-v3-asr-fp16:whisper-large-v3-asr-fp16

# ========================================
# URL Download Settings - Загрузка видео по URL
# ========================================

# Белый список доменов для скачивания (через запятую)
ALLOWED_URL_DOMAINS=youtube.com,youtu.be,vimeo.com,mironenko.org,docs.mironenko.org

# Максимальный размер скачиваемого файла в МБ
MAX_DOWNLOAD_SIZE_MB=2048

# Таймаут скачивания в секундах
DOWNLOAD_TIMEOUT_SECONDS=600

# ========================================
# oMLX — разбивка аудио по тишине
# ========================================

# Максимальная длительность одного сегмента для oMLX API в секундах (по умолчанию: 3000 = 50 мин)
OMLX_MAX_AUDIO_DURATION_SEC=3000
# Минимальный разрыв тишины в миллисекундах для объединения соседних не-тихих чанков (по умолчанию: 2000 = 2 сек)
OMLX_SILENCE_GAP_MS=2000
